# CircleCI env vars — add in Project Settings (never commit real values)

# --- Required: database ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Required: all 22 tickers (comma-separated, NO spaces) ---
# See tickers.example.txt
RECOMMENDATION_TICKERS=RELIANCE.NS,TCS.NS,HDFCBANK.NS,INFY.NS,ICICIBANK.NS,SBIN.NS,WIPRO.NS,BAJAJFINSV.NS,LT.NS,MARUTI.NS,BHARTIARTL.NS,ITC.NS,SUNPHARMA.NS,AXISBANK.NS,NESTLEIND.NS,KOTAKBANK.NS,ASIANPAINT.NS,LTTS.NS,TECHM.NS,CIPLA.NS,BTC-USD,ETH-USD

# --- Required: LLM (GLM 5.2 via Z.ai Anthropic-compatible gateway) ---
Z_API_KEY=
# or GLM_API_KEY= or ANTHROPIC_AUTH_TOKEN=
LLM_PROVIDER=***REMOVED***
LLM_BACKEND_URL=***REMOVED***
DEEP_THINK_LLM=glm-5.2
QUICK_THINK_LLM=glm-5.2

# --- Optional: Z.ai overload / rate-limit tuning ---
# Shards run sequentially in CircleCI. Remove SHARD_START_DELAY_SEC from project env if set.
# LLM_HTTP_MAX_RETRIES=2          # fail fast; propagate retry waits minutes
# LLM_REQUEST_GAP_SEC=8           # pause between each LLM call
# BATCH_TICKER_DELAY_SEC=60
# PROPAGATE_MAX_ATTEMPTS=8
# PROPAGATE_RETRY_DELAY_SEC=180
# PROPAGATE_RETRY_MAX_DELAY_SEC=600
# LLM_PREFLIGHT_MAX_ATTEMPTS=10
# LLM_PREFLIGHT_STRICT=0
# MAX_POSITION_INR=25000
# MIN_HOLD_DAYS=90
# THESIS_BREAK_LOSS_PCT=10
# SELL exit penalty (flat INR; default 150 — STT+DP+brokerage paper model on delivery sell)
# SELL_TRANSACTION_CHARGE_INR=150
# Optional buy-side charge (0 = none; real delivery has ~₹50–60 STT+stamp on ₹50k buy)
# BUY_TRANSACTION_CHARGE_INR=0
# PRICE_REFRESH_RATIO=0.03
# MAX_CACHE_AGE_DAYS=10