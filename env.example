# CircleCI env vars — add in Project Settings (never commit real values)

# --- Required: database ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Required: all 30 tickers (comma-separated, NO spaces) ---
# See tickers.example.txt
RECOMMENDATION_TICKERS=RELIANCE.NS,TCS.NS,HDFCBANK.NS,INFY.NS,ICICIBANK.NS,SBIN.NS,WIPRO.NS,BAJFINANCE.NS,BAJAJFINSV.NS,LT.NS,MARUTI.NS,BHARTIARTL.NS,HINDUNILVR.NS,ITC.NS,SUNPHARMA.NS,AXISBANK.NS,NESTLEIND.NS,KOTAKBANK.NS,ADANIENT.NS,ADANIPORTS.NS,M&M.NS,TITAN.NS,NTPC.NS,ULTRACEMCO.NS,ASIANPAINT.NS,LTTS.NS,TECHM.NS,CIPLA.NS,BTC-USD,ETH-USD

# --- Required: LLM (GLM 5.2 via Z.ai Anthropic-compatible gateway) ---
Z_API_KEY=
# or GLM_API_KEY= or ANTHROPIC_AUTH_TOKEN=
LLM_PROVIDER=anthropic
LLM_BACKEND_URL=https://api.z.ai/api/anthropic
DEEP_THINK_LLM=glm-5.2
QUICK_THINK_LLM=glm-5.2

# --- Optional: Z.ai overload / rate-limit tuning ---

# LLM_HTTP_MAX_RETRIES=2
# LLM_REQUEST_GAP_SEC=8
# BATCH_TICKER_DELAY_SEC=30
# PROPAGATE_MAX_ATTEMPTS=5
# PROPAGATE_RETRY_DELAY_SEC=120
# PROPAGATE_RETRY_MAX_DELAY_SEC=300
# MIN_CRYPTO_BUY_NOTIONAL_INR=500
# USD_INR_RATE=85
# MAX_POSITION_INR=25000
# MIN_WALLET_CASH_RESERVE_INR=5000
# MIN_HOLD_DAYS=90
# THESIS_BREAK_LOSS_PCT=10
# SELL exit penalty (flat INR; default 150 — STT+DP+brokerage paper model on delivery sell)
# SELL_TRANSACTION_CHARGE_INR=150
# Optional buy-side charge (0 = none; real delivery has ~₹50–60 STT+stamp on ₹50k buy)
# BUY_TRANSACTION_CHARGE_INR=0
# PRICE_REFRESH_RATIO=0.03
# MAX_CACHE_AGE_DAYS=10
# Verified real-data gates for AI recommendations/execution
# DATA_VENDOR_STOCKS=yfinance
# DATA_VENDOR_INDICATORS=yfinance
# DATA_VENDOR_FUNDAMENTALS=yfinance
# DATA_VENDOR_NEWS=yfinance
# MAX_MARKET_DATA_STALE_DAYS=5

# --- Optional: US macro data (FRED) for news analyst ---
# Required for real CPI / unemployment / yields in reports (not just DATA_UNAVAILABLE).
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# Add the same key locally in swing-trader/.env.local and in CircleCI project env.
# FRED_API_KEY=
# TRADINGAGENTS_VENDOR_MACRO_DATA=fred
# TRADINGAGENTS_VENDOR_PREDICTION_MARKETS=polymarket

# --- Optional: social fetch pacing (Reddit old.reddit JSON + RSS fallback) ---
# JSON works locally; GitHub Actions/datacenter IPs often get WAF 403 on JSON.
# Swing cron sets REDDIT_FETCH_MODE=rss in .github/workflows/ai-recommendations-swing.yml
# REDDIT_FETCH_MODE=json
# REDDIT_RSS_FALLBACK=1
# REDDIT_INTER_REQUEST_DELAY_SEC=5.0
# SOCIAL_FETCH_CACHE_TTL_SEC=300

# --- DB: full analyst reports (migration 013) ---
# Cron stores CLI-style complete_report + portfolio_context_snapshot in
# ai_recommendation_cache.full_report. Apply swing-trader migration 013 on Supabase
# before deploying this agent code: npx tsx scripts/run-migration.ts